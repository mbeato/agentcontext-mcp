{
  "name": "@mbeato/agentcontext-mcp",
  "version": "0.1.2",
  "mcpName": "io.github.mbeato/agentcontext",
  "description": "MCP server for @mbeato/agentcontext — exposes read_agent_context and convert_agent_context tools so any MCP-aware agent can normalize CLAUDE.md / AGENTS.md / .cursor/rules / .clinerules / .windsurf/rules.",
  "type": "module",
  "bin": {
    "agentcontext-mcp": "./dist/server.js"
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/index.ts --outfile dist/server.js --target=node --minify --banner '#!/usr/bin/env node'",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agents.md",
    "AGENTS.md",
    "CLAUDE.md",
    "cursor-rules",
    "clinerules",
    "windsurf",
    "ai-coding-agent"
  ],
  "author": "Max Beato",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mbeato/agentcontext.git",
    "directory": "mcp"
  },
  "homepage": "https://agentsmd.apimesh.xyz",
  "dependencies": {
    "@mbeato/agentcontext": "^0.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
